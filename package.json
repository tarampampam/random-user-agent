    "test:cover": "vitest --run --dir ./src --coverage --coverage.provider=v8 --coverage.reporter=clover --coverage.reporter=text-summary",
    "watch": "vite build --watch --minify=false",
    "build": "tsc --noEmit && vite build"
  },
