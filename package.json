    "archiver": "^7.0.1",
    "eslint": "^9.39.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jest-environment-jsdom": "^30.4.1",
    "npm": "^11.16.0",
    "prettier": "^3.8.3",
